# Database — Neon Postgres (distinct per environment: local / staging / production).
# For a free Neon DB: create a project at https://neon.tech, then copy the
# pooled connection string here. Include sslmode=require for Neon.
# Example: postgresql://user:password@ep-xxx.ap-southeast-1.aws.neon.tech/dbname?sslmode=require
DATABASE_URL="postgresql://user:password@localhost:5432/out_of_office?schema=public"

# Auth.js
AUTH_SECRET=""
AUTH_URL="http://localhost:3000"

# Admin panel (pragmatic single-password gate — to be replaced by role-based
# OTP auth, Req 11.1). ADMIN_PASSWORD gates /admin; ADMIN_SESSION_SECRET signs
# the httpOnly session cookie (HMAC-SHA256). Both are server-only secrets.
ADMIN_PASSWORD=""
ADMIN_SESSION_SECRET=""

# Razorpay (use TEST keys in all non-production environments)
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""
RAZORPAY_WEBHOOK_SECRET=""

# Anthropic Claude (model id read from config, not hardcoded). The AI slogan
# pipeline (Review Queue at /admin/ai) is DORMANT behind FLAG_AI_STUDIO. When
# ANTHROPIC_API_KEY is absent, generation returns a clear "not configured" error
# and makes NO network call — the app still builds and runs.
ANTHROPIC_API_KEY=""
CLAUDE_MODEL_ID=""
# Optional per-million-token pricing (integer paise) used to estimate AI run
# cost for the generation-run audit (Req 12.9). Defaults 250 / 1250 when unset.
CLAUDE_INPUT_PAISE_PER_MTOK="250"
CLAUDE_OUTPUT_PAISE_PER_MTOK="1250"

# Owner_Input defaults for AI-generated products (Req 15.1). Default variants are
# created for every combination of AI_DEFAULT_COLOR × AI_DEFAULT_SIZES with
# AI_DEFAULT_FIT, priced at AI_DEFAULT_BASE_PRICE_PAISE (integer paise).
AI_DEFAULT_COLOR="Black"
AI_DEFAULT_FIT="Regular"
AI_DEFAULT_SIZES="S,M,L,XL"
AI_DEFAULT_BASE_PRICE_PAISE="79900"

# Transactional email (Req 18.1, 18.2). Notifications send via the Resend HTTP
# API when BOTH are set; otherwise the app logs emails to the console (dev) and
# never blocks the order flow. FROM_EMAIL must be a verified Resend sender.
RESEND_API_KEY=""
FROM_EMAIL="Out of Office <orders@outofoffice.example>"

# Owner_Input maximum notification delivery retries after an initial failure
# (Req 18.4). Non-negative integer; defaults to 3 when unset.
NOTIFICATION_MAX_RETRIES="3"

# Newsletter (Req 20.1) — the default subscription source label recorded with
# each signup. Optional; the footer form sends "footer" explicitly.
NEWSLETTER_DEFAULT_SOURCE="footer"

# Team-pack discount (Req 20.3) — Owner_Input. When the total ordered quantity
# is at or above TEAM_PACK_MIN_QTY, TEAM_PACK_DISCOUNT_PAISE is deducted, floored
# so the order total is never below 0 paise. Wired via applyTeamPackDiscount.
TEAM_PACK_MIN_QTY="10"
TEAM_PACK_DISCOUNT_PAISE="50000"

# Object storage (S3 / R2) + Cloudinary
S3_BUCKET=""
S3_REGION=""
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
CLOUDINARY_URL=""

# AI mockup preview object storage (Req 14.5, 14.9) — generic HTTP PUT scheme,
# no AWS SDK required. When R2_PUBLIC_BASE_URL is set the Mockup_Renderer stores
# the composed preview and records its public URL on the Design + Product. If a
# presigned/PUT upload URL is provided the preview is PUT there via fetch first;
# a failed upload records NO url and returns an error (Req 14.9). When these are
# unset the renderer falls back to an inline data-URL placeholder with a note
# and the build/app run without any storage configured.
#   R2_PUBLIC_BASE_URL   Public base URL objects are served from, e.g.
#                        https://cdn.example.com/mockups (no trailing slash needed).
#   R2_UPLOAD_BASE_URL   Optional base URL to HTTP PUT the object to. Defaults to
#                        R2_PUBLIC_BASE_URL when unset (same bucket, public write).
#   R2_UPLOAD_TOKEN      Optional bearer token sent as Authorization on the PUT.
R2_PUBLIC_BASE_URL=""
R2_UPLOAD_BASE_URL=""
R2_UPLOAD_TOKEN=""

# Print-on-Demand (POD) provider (Req 16 — dormant behind FLAG_POD). The POD
# adapter is a stub that makes NO network call and returns "not configured"
# until BOTH the flag is enabled and these are set. With the flag off (default)
# all fulfillment routes through the active self-fulfillment implementation.
POD_API_KEY=""
POD_BASE_URL=""

# Sentry error monitoring (Req 24.6, 24.7). Leave blank to disable — with no DSN
# the app builds and runs and no error reports are sent. NEXT_PUBLIC_SENTRY_DSN
# enables client-side reporting; SENTRY_DSN covers server-side. Typically the
# same DSN value.
SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_DSN=""

# Analytics (Req 19.4, 19.5). All optional — with no keys set, no analytics
# scripts are injected and event tracking is a silent no-op.
# GA4 measurement id, e.g. G-XXXXXXXXXX
NEXT_PUBLIC_GA4_ID=""
# PostHog project API key and host (defaults to https://us.i.posthog.com)
NEXT_PUBLIC_POSTHOG_KEY=""
NEXT_PUBLIC_POSTHOG_HOST="https://us.i.posthog.com"

# Brand configuration (Owner_Input) — required at startup (Req 22.1, 22.6)
BRAND_NAME="Out of Office"
BRAND_LOGO_URL="https://cdn.example.com/corporate-cult/logo.svg"
# JSON object of design color tokens (must be a non-empty object)
BRAND_COLOR_TOKENS='{"primary":"#111111","accent":"#e11d48","bg":"#ffffff"}'
STORE_TIMEZONE="Asia/Kolkata"

# Tax / invoicing (Owner_Input) — required at startup (Req 9.1, 9.6)
GST_RATE_PERCENT="5"          # 0..28
SELLER_GSTIN=""               # exactly 15 characters (leave blank until you have it)
GARMENT_HSN="61091000"
SELLER_STATE="Karnataka"      # seller's registered state (CGST/SGST vs IGST)
LEGAL_ENTITY_NAME="Out of Office Retail Pvt Ltd"
LEGAL_ENTITY_ADDRESS="No. 1, MG Road, Bengaluru, Karnataka 560001"

# Support & grievance contact (Owner_Input) — shown on legal / contact pages
# (Req 21.5). Leave blank to render clearly-marked placeholders on those pages.
SUPPORT_EMAIL="support@outofoffice.example"
GRIEVANCE_OFFICER_NAME="Grievance Officer"
BUSINESS_ADDRESS="No. 1, MG Road, Bengaluru, Karnataka 560001"
GRIEVANCE_ACK_HOURS="48"      # hours within which grievances are acknowledged

# Public site origin — used for canonical/SEO URLs
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Feature flags — all default DISABLED (Req 22.2). Set to true/1/yes/on to enable.
# NOTE: FLAG_AI_STUDIO (AI slogan pipeline / Review Queue at /admin/ai) and
# FLAG_POD (print-on-demand fulfillment routing) are COMPLETE but DORMANT: they
# default OFF. While off, /admin/ai returns 404 (discloses nothing) and all
# fulfillment routes through self-fulfillment. Flip to "true" to activate.
FLAG_AI_STUDIO="false"
FLAG_REVIEWS="false"
FLAG_HOMEPAGE_3D="false"
FLAG_POD="false"
FLAG_SHIPPING_AGGREGATOR="false"
FLAG_WHATSAPP="false"
FLAG_REFERRAL="false"
FLAG_ABANDONED_CART="false"

# Shipping thresholds (integer paise) (Req 17.2)
FREE_SHIPPING_THRESHOLD_PAISE="99900"
FLAT_SHIPPING_CHARGE_PAISE="7900"

# COD limits (integer paise) (Req 8.8)
COD_MIN_PAISE="0"
COD_MAX_PAISE="500000"

# Moderation thresholds (0..1, review < autoReject) (Req 13.5).
# LENIENT defaults (Owner_Input): the automatic safety check is deliberately
# permissive so it does not reject good slogan ideas. Only clearly-prohibited
# content is auto-rejected. A candidate is sent to human review only when its
# violation-confidence score is >= REVIEW (0.75) and < AUTO_REJECT (0.95); at or
# above AUTO_REJECT it is auto-rejected. Everything below REVIEW is ADMITted.
# NOTE: prohibited *categories* (real hate/defamation of real people, sexual,
# harassment, threats, self-harm, illegal activity) ALWAYS auto-reject
# regardless of these numbers — that safety floor cannot be tuned away.
# Raise/lower these to tune tone; keep review < autoReject and both in 0..1.
MODERATION_REVIEW_THRESHOLD="0.75"
MODERATION_AUTO_REJECT_THRESHOLD="0.95"

# Storefront thresholds
LOW_STOCK_THRESHOLD="5"
CROSS_SELL_COUNT="4"
RETURNS_WINDOW="7 days"
DISPATCH_TIME="2-3 business days"

# Rate limits — optional JSON override; sensible defaults applied otherwise (Req 23.7)
# RATE_LIMITS='{"otpRequest":{"max":3,"windowSeconds":600,"minIntervalSeconds":30}}'
